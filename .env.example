# Postgres (Railway sets this automatically when you reference the Postgres service)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Local fallback (optional) — when DATABASE_URL is unset, sql.js writes to this file
DATABASE_PATH=./formflow.db

# Server
PORT=3001
APP_URL=http://localhost:3001
APP_NAME=Formz
JWT_SECRET=change-me-in-prod

# Uploads storage — where PDFs for property listings are written.
# Local dev: leave unset (defaults to ./server/uploads).
# Railway prod: attach a persistent volume at /data and set this to /data/uploads.
# Without this, uploaded files are wiped on every container restart.
UPLOADS_DIR=

# AI
ANTHROPIC_API_KEY=

# Gmail OAuth (per-agent send)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Email fallbacks
MAKE_WEBHOOK_URL=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@formflow.co.nz
